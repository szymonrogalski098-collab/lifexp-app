rules_version = '2';

// LifeXP — produkcyjne reguły Firestore
// Wgranie: Firebase Console → Firestore Database → zakładka "Rules" → wklej → Publish.
// Model: właściciel ma pełny dostęp do swoich danych; rodzic (po emailu) ma read-only.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Rodzic = zalogowany użytkownik, którego email == parentEmail dziecka.
    // Dla zapytań listujących (parent.html) reguła sprawdza każdy zwracany dokument,
    // więc zapytanie MUSI mieć where('parentEmail','==', <email rodzica>).
    function isParentOfDoc() {
      return isSignedIn() && resource.data.parentEmail == request.auth.token.email;
    }

    // Dla podkolekcji: dociągamy dokument rodzica (users/{uid}) i porównujemy email.
    function isParentOf(uid) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(uid)).data.parentEmail == request.auth.token.email;
    }

    // Admin systemu zgłoszeń błędów — jedyne konto, które widzi WSZYSTKIE bugReports
    // (właściciel danego zgłoszenia i tak widzi swoje własne, patrz reguła niżej).
    function isBugAdmin() {
      return isSignedIn() && request.auth.token.email == 'szymonrogalski098@gmail.com';
    }

    match /users/{uid} {
      allow read:   if isOwner(uid) || isParentOfDoc();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);

      // Wszystkie podkolekcje (activities, dailyLog, gamingSessions, purchases,
      // chores, chorePayouts, choreDefs, activityDefs, money, moneyLoans, ...).
      // Rodzic (read-only) widzi wszystko OPRÓCZ prywatnych danych money trackera:
      // transakcje, kategorie, pożyczki i ustawienia limitu są tylko dla właściciela.
      // Z modułu Money rodzic czyta wyłącznie saldo (money/balance). Cele oszczędnościowe
      // to teraz cele z dashboardu (pole users/{uid}.goals, czytane wyżej z całym users/{uid}).
      // Uwaga: to celowo NIE jest wildcard {document=**} — wildcard dawałby unię
      // uprawnień i nie dałoby się z niego wyciąć wyjątków dla money.
      match /{col}/{docId} {
        allow write: if isOwner(uid);
        allow read:  if isOwner(uid) || (
          isParentOf(uid)
          && col != 'moneyTransactions'
          && col != 'moneyCategories'
          && col != 'moneyLoans'
          && col != 'fcmTokens'
          && !(col == 'money' && docId == 'settings')
        );
      }
    }

    // Zgłoszenia błędów — TOP-LEVEL (nie pod users/{uid}), bo panel admina musi
    // widzieć zgłoszenia wszystkich kont jedną kolekcją. Zgłaszający widzi tylko
    // swoje własne; tylko admin widzi wszystkie i może zmieniać status/kasować.
    match /bugReports/{id} {
      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.status in ['new', 'spam'];
      allow read:   if isSignedIn() && (resource.data.reporterUid == request.auth.uid || isBugAdmin());
      allow update, delete: if isBugAdmin();
    }

    // Lista słów wymaganych w opisie zgłoszenia (filtr spamu) — każdy zalogowany
    // może odczytać (potrzebne w przeglądarce zgłaszającego, żeby sklasyfikować
    // zgłoszenie przy wysyłce), edytować może tylko admin.
    match /bugReportsConfig/{id} {
      allow read:  if isSignedIn();
      allow write: if isBugAdmin();
    }
  }
}
